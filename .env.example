# App site origin only — do not include OAuth callback paths here.
# NEXT_PUBLIC_* is inlined at build time. For production OAuth, also set SITE_URL (runtime).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=https://desklabs.vercel.app

# Meta / Instagram OAuth (server only)
META_APP_ID=
# OAuth and token exchange only — not used for webhook signature validation
META_APP_SECRET=
# Meta webhook verify token for GET /api/webhooks/meta subscription challenge
META_WEBHOOK_VERIFY_TOKEN=
# Webhook POST signature validation only (HMAC SHA-256 / SHA-1)
META_WEBHOOK_APP_SECRET=
# Optional dev-only IG Business Account ID for direct Graph API validation logs
META_DEBUG_INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Deprecated: no longer used for signup. New users create their own workspace via /onboarding.
# BETA_JOIN_ORGANIZATION_ID=

# Optional: when set, website demo requests also create CRM leads + audit logs in this org.
DESKLABS_MARKETING_ORG_ID=

# OpenAI (server only)
OPENAI_API_KEY=

# WhatsApp (Evolution API, server only)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=desklabs-local-key
# Optional: map incoming WhatsApp webhooks to a workspace when no integration row exists
WHATSAPP_ORGANIZATION_ID=

